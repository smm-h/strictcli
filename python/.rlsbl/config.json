{
  "targets": [
    "pypi",
    "npm"
  ],
  "publish_mode": "ci",
  "push_timeout": 300,
  "pipelines": {
    "pypi": {
      "type": "pypi",
      "target": "pypi",
      "local": false
    },
    "npm": {
      "type": "npm",
      "target": "npm",
      "local": false,
      "provenance": true
    }
  },
  "coverage_unit": "commit"
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "The 'validate' feature (custom validation callback on flags) is intentionally excluded from this conformance schema because it is a callable that cannot be serialized to JSON. Both implementations support it (Flag.validate in Python, ValidateFn() in Go) but it is tested via unit tests, not conformance tests.",
  "title": "strictcli conformance test cases",
  "description": "Array of test cases for verifying strictcli implementations.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/test_case"
  },
  "minItems": 1,
  "$defs": {
    "test_case": {
      "type": "object",
      "required": ["name", "app", "argv", "expect"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Descriptive test name."
        },
        "skip_schema_validation": {
          "type": "boolean",
          "default": false,
          "description": "If true, this test case is exempt from schema validation (used for cases that intentionally craft invalid app definitions)."
        },
        "app": {
          "$ref": "#/$defs/app"
        },
        "argv": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command-line arguments (including the subcommand)."
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Environment variables to set before invoking the app."
        },
        "expect": {
          "$ref": "#/$defs/expect"
        }
      }
    },
    "app": {
      "type": "object",
      "required": ["name", "version", "help", "commands"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "help": { "type": "string" },
        "env_prefix": { "type": "string" },
        "config": {
          "type": "boolean",
          "default": false,
          "description": "If true, enable config file support and auto-register config subcommands."
        },
        "config_path": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "default": null,
          "description": "Override the default config file path. If null, uses XDG_CONFIG_HOME/<app>/config.<format>."
        },
        "config_format": {
          "type": "string",
          "enum": ["json", "toml"],
          "default": "json",
          "description": "Config file format: 'json' or 'toml'."
        },
        "global_flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/flag" },
          "description": "Flags declared on the App, parsed before the command name and available to every handler."
        },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/command" }
        },
        "groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/group" }
        },
        "checks_path": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "default": null,
          "description": "Override CWD-based discovery of checks.toml with an explicit path."
        },
        "checks_toml": {
          "type": "string",
          "description": "Raw TOML content to write as .strictcli/checks.toml for check conformance tests."
        },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/check" },
          "description": "Check stub definitions for code generation."
        }
      }
    },
    "check": {
      "type": "object",
      "required": ["name", "check_returns", "check_message"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "check_returns": { "enum": ["pass", "fail", "warn"] },
        "check_message": { "type": "string" },
        "check_details": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "group": {
      "type": "object",
      "required": ["name", "help"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "help": { "type": "string" },
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/command" }
        },
        "groups": {
          "type": "array",
          "items": { "$ref": "#/$defs/group" }
        }
      }
    },
    "command": {
      "type": "object",
      "required": ["name", "help"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "help": { "type": "string" },
        "deprecated": {
          "type": "boolean",
          "default": false,
          "description": "If true, this is a deprecated command. It must have deprecated_message and must NOT have handler_prints, handler_exit_code, flags, args, tags, mutex, dependencies, passthrough, or passthrough_handler_prints."
        },
        "deprecated_message": {
          "type": "string",
          "description": "Deprecation message shown when the command is invoked or listed in help. Required when deprecated is true."
        },
        "handler_prints": {
          "type": "string",
          "description": "Template string. {name} is replaced with the value of the arg/flag named 'name'."
        },
        "handler_exit_code": {
          "type": "integer",
          "default": 0,
          "description": "The integer value the generated handler returns. Used as the process exit code."
        },
        "passthrough": {
          "type": "boolean",
          "default": false,
          "description": "If true, the command is a passthrough command: no flag/arg parsing, handler receives raw args."
        },
        "passthrough_handler_prints": {
          "type": "string",
          "description": "Template for passthrough handler output. Receives name and raw args. Generated handler prints name:arg1,arg2,..."
        },
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/arg" }
        },
        "flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/flag" }
        },
        "tags": {
          "type": "array",
          "items": { "$ref": "#/$defs/tag" }
        },
        "mutex": {
          "type": "array",
          "items": { "$ref": "#/$defs/mutex_group" }
        },
        "dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/dependency" }
        }
      },
      "if": {
        "properties": { "deprecated": { "const": true } },
        "required": ["deprecated"]
      },
      "then": {
        "required": ["name", "help", "deprecated", "deprecated_message"],
        "properties": {
          "name": true,
          "help": true,
          "deprecated": true,
          "deprecated_message": true,
          "handler_prints": false,
          "handler_exit_code": false,
          "flags": false,
          "args": false,
          "tags": false,
          "mutex": false,
          "dependencies": false,
          "passthrough": false,
          "passthrough_handler_prints": false
        }
      }
    },
    "arg": {
      "type": "object",
      "required": ["name", "help"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "help": { "type": "string" },
        "required": { "type": "boolean", "default": true },
        "default": { "type": "string" },
        "variadic": {
          "type": "boolean",
          "default": false,
          "description": "If true, collects all remaining positional args into a list. Must be the last declared arg."
        }
      }
    },
    "flag": {
      "type": "object",
      "required": ["name", "help"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "help": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["str", "bool", "int", "float"],
          "default": "str"
        },
        "short": { "type": "string" },
        "default": {
          "oneOf": [
            { "type": "string" },
            { "type": "boolean" },
            { "type": "number" },
            { "type": "null" }
          ]
        },
        "env": { "type": "string" },
        "prefixed": { "type": "boolean", "default": true },
        "choices_str": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Choices for str-type flags."
        },
        "choices_int": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Choices for int-type flags."
        },
        "choices_float": {
          "type": "array",
          "items": { "type": "number" },
          "description": "Choices for float-type flags."
        },
        "repeatable": { "type": "boolean", "default": false },
        "negatable": {
          "type": "boolean",
          "default": true,
          "description": "Whether --no-flagname negation is supported. Only meaningful for bool-type flags."
        }
      }
    },
    "tag": {
      "type": "object",
      "required": ["name", "flags"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/flag" }
        }
      }
    },
    "mutex_group": {
      "type": "object",
      "required": ["flags"],
      "additionalProperties": false,
      "properties": {
        "flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/flag" },
          "minItems": 2
        }
      }
    },
    "co_required": {
      "type": "object",
      "required": ["type", "flags"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "co_required" },
        "flags": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        }
      }
    },
    "requires": {
      "type": "object",
      "required": ["type", "flag", "depends_on"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "requires" },
        "flag": { "type": "string" },
        "depends_on": { "type": "string" }
      }
    },
    "implies": {
      "type": "object",
      "required": ["type", "flag", "implies", "value"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "implies" },
        "flag": { "type": "string" },
        "implies": { "type": "string" },
        "value": { "type": "boolean" }
      }
    },
    "dependency": {
      "oneOf": [
        { "$ref": "#/$defs/co_required" },
        { "$ref": "#/$defs/requires" },
        { "$ref": "#/$defs/implies" }
      ]
    },
    "expect": {
      "type": "object",
      "required": ["exit_code"],
      "additionalProperties": false,
      "properties": {
        "exit_code": { "type": "integer" },
        "stdout_contains": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Substring(s) that must appear in stdout."
        },
        "stdout_equals": {
          "type": "string",
          "description": "Exact stdout content."
        },
        "stderr_contains": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Substring(s) that must appear in stderr."
        },
        "stderr_equals": {
          "type": "string",
          "description": "Exact stderr content."
        },
        "stdout_not_contains": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Substring(s) that must NOT appear in stdout."
        },
        "stderr_not_contains": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Substring(s) that must NOT appear in stderr."
        }
      }
    }
  }
}

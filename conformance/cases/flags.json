  {
    "name": "flags: str flag with default, omitted uses default",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "default": "text"
            }
          ],
          "handler_prints": "format={format}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "format=text"
    }
  },
  {
    "name": "flags: str flag with default, provided overrides default",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "default": "text"
            }
          ],
          "handler_prints": "format={format}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--format",
      "json"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "format=json"
    }
  },
  {
    "name": "flags: required str flag missing produces error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target"
            }
          ],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "required",
      "stderr_equals": "error: flag '--target' is required\ntry 'myapp cmd --help'"
    }
  },
  {
    "name": "flags: bool flag=value syntax is rejected",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose"
            }
          ],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--verbose=true"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "boolean flag",
      "stderr_equals": "error: flag '--verbose' is a boolean flag and does not take a value\ntry 'myapp cmd --help'"
    }
  },
  {
    "name": "flags: negatable false rejects --no-flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose",
              "negatable": false
            }
          ],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--no-verbose"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "unknown flag",
      "stderr_equals": "error: unknown flag '--no-verbose'\ntry 'myapp cmd --help'"
    }
  },
  {
    "name": "flags: negatable true allows --no-flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose",
              "negatable": true
            }
          ],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--no-verbose"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "verbose=false"
    }
  }
]

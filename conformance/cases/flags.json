  {
    "name": "flags: short flag for str",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "short": "t",
              "help": "the target"
            }
          ],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": [
      "cmd",

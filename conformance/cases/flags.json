[
  {
    "name": "flags: str flag with space syntax",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target"
            }
          ],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--target",
      "foo"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "target=foo"
    }
  },
  {
    "name": "flags: str flag with equals syntax",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target"
            }
          ],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--target=bar"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "target=bar"
    }
  },

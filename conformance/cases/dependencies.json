  {
    "name": "dependencies: implies trigger set auto-sets target",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "fast",
              "type": "bool",
              "help": "fast mode"
            },
            {
              "name": "embeddings",
              "type": "bool",
              "help": "enable embeddings",
              "default": true
            }
          ],
          "dependencies": [
            {"type": "implies", "flag": "fast", "implies": "embeddings", "value": false}
          ],
          "handler_prints": "fast={fast} embeddings={embeddings}"
        }
      ]
    },
    "argv": ["cmd", "--fast"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": ["fast=true", "embeddings=false"]
    }
  },

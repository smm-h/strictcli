  {
    "name": "dependencies: requires both provided ok",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "verbose output"
            },
            {
              "name": "output",
              "type": "str",
              "help": "output file",
              "default": "none"
            }
          ],
          "dependencies": [
            {"type": "requires", "flag": "verbose", "depends_on": "output"}
          ],
          "handler_prints": "verbose={verbose} output={output}"
        }
      ]
    },
    "argv": ["cmd", "--verbose", "--output", "log.txt"],
    "expect": {
      "exit_code": 0
    }
  },

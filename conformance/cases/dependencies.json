[
  {
    "name": "dependencies: co_required both provided ok",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "output",
              "type": "str",
              "help": "output file",
              "default": "none"
            },
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "default": "none"
            }
          ],
          "dependencies": [
            {"type": "co_required", "flags": ["output", "format"]}
          ],
          "handler_prints": "output={output} format={format}"
        }
      ]
    },
    "argv": ["cmd", "--output", "file.txt", "--format", "json"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": ["output=file.txt", "format=json"]
    }
  },
  {
    "name": "dependencies: co_required neither provided ok",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "output",
              "type": "str",
              "help": "output file",
              "default": "none"
            },
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "default": "none"
            }
          ],
          "dependencies": [
            {"type": "co_required", "flags": ["output", "format"]}
          ],
          "handler_prints": "output={output} format={format}"
        }
      ]
    },
    "argv": ["cmd"],
    "expect": {
      "exit_code": 0
    }
  },
  {
    "name": "dependencies: co_required one provided error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "output",
              "type": "str",
              "help": "output file",
              "default": "none"
            },
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "default": "none"
            }
          ],
          "dependencies": [
            {"type": "co_required", "flags": ["output", "format"]}
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": ["cmd", "--output", "file.txt"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "flags --output, --format must be used together"
    }
  },
  {
    "name": "dependencies: co_required second only error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",

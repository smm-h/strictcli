            },
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "default": "none"
            }
          ],
          "dependencies": [
            {"type": "co_required", "flags": ["output", "format"]}
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": ["cmd", "--format", "json"],
    "expect": {

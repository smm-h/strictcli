[
  {
    "name": "reserved_global_flags: global flag named 'help' is rejected",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "global_flags": [
        {
          "name": "help",
          "type": "str",
          "help": "should be rejected"
        }
      ],
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": ["cmd"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "reserved"
    }
  },
  {

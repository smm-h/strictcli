[
  {
    "name": "registration: empty app help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "must be a non-empty string",
      "stderr_equals": "error: App.help must be a non-empty string"
    }
  },
  {
    "name": "registration: empty command help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "missing help text",
      "stderr_equals": "error: command \"cmd\": missing help text"
    }
  },
  {
    "name": "registration: empty flag help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": ""
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "must be a non-empty string",
      "stderr_equals": "error: Flag.help must be a non-empty string"
    }
  },
  {
    "name": "registration: empty arg help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "file",
              "help": ""
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "test.txt"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "must be a non-empty string",
      "stderr_equals": "error: Arg.help must be a non-empty string"
    }
  },
  {
    "name": "registration: empty group help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "groups": [
        {
          "name": "config",
          "help": "",
          "commands": [
            {
              "name": "show",
              "help": "display config",
              "handler_prints": "ok"
            }
          ]
        }
      ],
      "commands": []
    },
    "argv": [
      "config",
      "show"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "must be a non-empty string",
      "stderr_equals": "error: Group.help must be a non-empty string"
    }
  },
  {
    "name": "registration: repeatable bool flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose",
              "repeatable": true
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "repeatable",
        "bool"
      ],
      "stderr_equals": "error: Flag \"verbose\": repeatable is incompatible with type=bool"
    }
  },
  {
    "name": "registration: choices on bool flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose",
              "choices_str": [
                "yes",
                "no"
              ]
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "choices",
        "bool"
      ],
      "stderr_equals": "error: Flag \"verbose\": choices is incompatible with type=bool"
    }
  },
  {
    "name": "registration: mutex group with one flag",
    "skip_schema_validation": true,
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "mutex": [
            {
              "flags": [
                {
                  "name": "verbose",
                  "type": "bool",
                  "help": "verbose output"
                }
              ]
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "at least 2",
      "stderr_equals": "error: command \"cmd\": mutex group must have at least 2 flags, got 1"
    }
  },
  {
    "name": "registration: duplicate flag names",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target"
            },
            {
              "name": "target",
              "type": "str",
              "help": "the target again"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "duplicate",
      "stderr_equals": "error: command \"cmd\": duplicate flag name \"target\""
    }
  },
  {
    "name": "registration: duplicate arg names",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "file",
              "help": "the file"
            },
            {
              "name": "file",
              "help": "the file again"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "a.txt",
      "b.txt"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "duplicate",
      "stderr_equals": "error: command \"cmd\": duplicate arg name \"file\""
    }
  },
  {
    "name": "registration: flag collides with global flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "global_flags": [
        {
          "name": "verbose",
          "type": "bool",
          "help": "enable verbose output"
        }
      ],
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "collides",
      "stderr_equals": "error: command \"cmd\": flag \"verbose\" collides with a global flag"
    }
  },
  {
    "name": "registration: env prefix mismatch",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target",
              "env": "WRONG_TARGET"
            }
          ],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--target",
      "prod"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "must start with",
      "stderr_equals": "error: command \"cmd\": env var \"WRONG_TARGET\" for flag \"target\" must start with \"MYAPP_\" (or set prefixed=false)"
    }
  },
  {
    "name": "registration: required arg with default",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "file",
              "help": "the file",
              "required": true,
              "default": "default.txt"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "test.txt"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "required arg cannot have a default",
      "stderr_equals": "error: required arg cannot have a default"
    }
  },
  {
    "name": "registration: duplicate global flag names",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "global_flags": [
        {
          "name": "verbose",
          "type": "bool",
          "help": "enable verbose output"
        },
        {
          "name": "verbose",
          "type": "bool",
          "help": "enable verbose output again"
        }
      ],
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "duplicate",
      "stderr_equals": "error: duplicate global flag name \"verbose\""
    }
  },
  {
    "name": "registration: int flag with string default",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "port",
              "type": "int",
              "help": "the port",
              "default": "abc"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "type=int requires an int default",
        "port"
      ],
      "stderr_equals": "error: Flag \"port\": type=int requires an int default, got 'str'"
    }
  },
  {
    "name": "registration: default not in choices",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "choices_str": ["json", "csv"],
              "default": "xml"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "default",
        "not in choices"
      ],
      "stderr_equals": "error: Flag \"format\": default 'xml' is not in choices ['json', 'csv']"
    }
  },
  {
    "name": "registration: flag in multiple mutex groups",
    "skip_schema_validation": true,
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "mutex": [
            {
              "flags": [
                {
                  "name": "json",
                  "type": "bool",
                  "help": "output as json"
                },
                {
                  "name": "csv",
                  "type": "bool",
                  "help": "output as csv"
                }
              ]
            },
            {
              "flags": [
                {
                  "name": "csv",
                  "type": "bool",
                  "help": "output as csv"
                },
                {
                  "name": "xml",
                  "type": "bool",
                  "help": "output as xml"
                }
              ]
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "appears in multiple mutex groups",
      "stderr_equals": "error: command \"cmd\": flag \"csv\" appears in multiple mutex groups"
    }
  },
  {
    "name": "registration: empty choices list",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "choices_str": []
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "choices must be a non-empty list",
      "stderr_equals": "error: Flag \"format\": choices must be a non-empty list"
    }
  },
  {
    "name": "registration: global flag with empty help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "global_flags": [
        {
          "name": "verbose",
          "type": "bool",
          "help": ""
        }
      ],
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "must be a non-empty string",
      "stderr_equals": "error: Flag.help must be a non-empty string"
    }
  }
]

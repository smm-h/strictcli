      "infra_root": { "MYAPP_HOME": "/var/lib/myapp" },
      "commands": [
        {
          "name": "run",
          "help": "Run it",
          "handler_style": "context",
          "handler_prints": "{source:db}:{db}",
          "flags": [
            {
              "name": "db",
              "help": "Database path",
              "type": "str",
              "default_relative_to_root": { "env_var": "MYAPP_HOME", "parts": ["db.sqlite"] }
            }
          ]
        }
      ]
    },
    "argv": ["--hermetic", "run"],
    "env": { "MYAPP_HOME": "/opt/data" },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "infra:/opt/data/db.sqlite"
    }
  },
  {
    "name": "infra: CLI value overrides the marker default, source is 'cli'",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "Test infra CLI override",
      "infra_root": { "MYAPP_HOME": "/var/lib/myapp" },
      "commands": [
        {

[
  {
    "name": "infra: flag default resolves through root (env set), source is 'infra'",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "Test infra root resolution",
      "infra_root": { "MYAPP_HOME": "/var/lib/myapp" },
      "commands": [
        {
          "name": "run",
          "help": "Run it",
          "handler_style": "context",
          "handler_prints": "{source:db}:{db}",
          "flags": [
            {
              "name": "db",
              "help": "Database path",
              "type": "str",
              "default_relative_to_root": { "env_var": "MYAPP_HOME", "parts": ["db.sqlite"] }
            }
          ]
        }
      ]
    },
    "argv": ["run"],
    "env": { "MYAPP_HOME": "/opt/data" },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "infra:/opt/data/db.sqlite"
    }
  },
  {
    "name": "infra: root unset -> declared default resolves, source is 'infra'",
    "app": {
      "name": "myapp",
      "version": "1.0.0",

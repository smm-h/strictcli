            {
              "name": "db",
              "help": "Database path",
              "type": "str",
              "default_relative_to_root": { "env_var": "MYAPP_HOME", "parts": ["db.sqlite"] }
            }
          ]
        }
      ]
    },
    "argv": ["run"],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "infra:/var/lib/myapp/db.sqlite"
    }
  },
  {
    "name": "infra: hermetic still resolves the marker (root has no argv dependency)",

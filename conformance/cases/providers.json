[
  {
    "name": "providers: registered provider check runs and passes",
    "app": {
      "name": "testapp",
      "version": "1.0.0",
      "help": "test",
      "commands": [],
      "providers": [
        [
          {
            "name": "prov-lint",
            "tags": ["release"],
            "severity": "error",
            "fast": true,
            "pure": true,
            "needs_network": false,
            "depends_on": [],
            "scope": "",
            "mint": "passed",
            "message": "provider lint ok"
          }
        ]
      ]
    },
    "argv": ["check", "--all"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": ["PASS", "prov-lint"]
    }
  },
  {
    "name": "providers: provider check fail outcome exits 1",
    "app": {
      "name": "testapp",
      "version": "1.0.0",
      "help": "test",
      "commands": [],
      "providers": [
        [
          {
            "name": "prov-lint",
            "tags": ["release"],
            "severity": "error",
            "fast": true,
            "pure": true,
            "needs_network": false,
            "depends_on": [],
            "scope": "",
            "mint": "found",
            "message": "lint errors found",
            "problems": [
              { "severity": "error", "text": "lint errors found" }
            ]
          }
        ]
      ]
    },
    "argv": ["check", "--all"],
    "expect": {
      "exit_code": 1,
      "stdout_contains": ["FAIL", "prov-lint"]
    }
  },
  {

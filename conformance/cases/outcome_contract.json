[
  {
    "name": "outcome: exit-only return sets the process exit code",
    "app": {
      "name": "outcomeapp",
      "version": "1.0.0",
      "help": "Test the Outcome return contract",
      "commands": [
        {
          "name": "run",
          "help": "Return an exit-only outcome",
          "handler_returns": { "kind": "exit", "code": 3 }
        }
      ]
    },
    "argv": ["run"],
    "expect": {
      "exit_code": 3,
      "stdout_equals": ""
    }
  },
  {
    "name": "outcome: data-only return prints one compact JSON line (byte-identical across languages)",
    "app": {
      "name": "outcomeapp",
      "version": "1.0.0",
      "help": "Test the Outcome data contract",
      "commands": [
        {
          "name": "run",
          "help": "Return a data-only outcome",
          "handler_returns": {
            "kind": "data",
            "data": { "count": 3, "name": "strictcli" }
          }
        }
      ]
    },
    "argv": ["run"],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "{\"count\":3,\"name\":\"strictcli\"}"
    }
  },
  {
    "name": "outcome: exit+data return prints data AND sets exit code",
    "app": {
      "name": "outcomeapp",
      "version": "1.0.0",
      "help": "Test exit+data outcome",
      "commands": [
        {
          "name": "run",
          "help": "Return an exit+data outcome",
          "handler_returns": {
            "kind": "exit_data",
            "code": 2,
            "data": { "ok": false }
          }
        }
      ]
    },
    "argv": ["run"],
    "expect": {
      "exit_code": 2,
      "stdout_equals": "{\"ok\":false}"
    }
  },
  {
    "name": "outcome: None return (Python) / Exit(0) (Go) exits 0 with no data",
    "app": {
      "name": "outcomeapp",
      "version": "1.0.0",
      "help": "Test None-return outcome",
      "commands": [
        {
          "name": "run",
          "help": "Return None / Exit(0)",
          "handler_returns": { "kind": "none" }
        }
      ]
    },
    "argv": ["run"],
    "expect": {
      "exit_code": 0,
      "stdout_equals": ""
    }
  },
  {
    "name": "outcome: bad handler return is a hard error (Python and TypeScript; Go's type system forbids it)",
    "targets": ["python", "typescript"],
    "acknowledged_divergence": {
      "reason": "Python surfaces the bad return as an uncaught TypeError traceback (host paths, line numbers, Python type names: int/None/list); TypeScript prints the framework's one-line error with JS type names (number/undefined/Array). Both assert the shared 'command handler must return' contract via stderr_contains.",
      "streams": {"stderr": ["python"]}
    },
    "app": {
      "name": "outcomeapp",
      "version": "1.0.0",
      "help": "Test bad-return hard error",
      "commands": [
        {
          "name": "run",
          "help": "Return an invalid value",
          "handler_returns": { "kind": "bad" }
        }
      ]
    },
    "argv": ["run"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "command handler must return"
    }
  }
]

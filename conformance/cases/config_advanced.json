[
  {
    "name": "config: TOML config loading with typed values via config show",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "count = 42\ndebug = true\nrate = 3.14",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "count", "help": "a count", "type": "int", "default": 0},
            {"name": "debug", "help": "debug mode", "type": "bool", "default": false},
            {"name": "rate", "help": "a rate", "type": "float", "default": 0.0}
          ]
        }
      ]
    },
    "argv": ["config", "show", "--plain"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "count = 42",
        "(source: config)",
        "rate = 3.14",
        "debug ="
      ]
    }
  },
  {
    "name": "config: JSON config loading with typed values via config show",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_content": "{\"count\": 42, \"debug\": true, \"rate\": 3.14}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "count", "help": "a count", "type": "int", "default": 0},
            {"name": "debug", "help": "debug mode", "type": "bool", "default": false},
            {"name": "rate", "help": "a rate", "type": "float", "default": 0.0}
          ]
        }
      ]
    },
    "argv": ["config", "show", "--plain"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "count = 42  (source: config)",
        "rate = 3.14  (source: config)",
        "debug ="
      ]
    }
  },
  {
    "name": "config: precedence - config wins over default",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "port = 9090",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "port={port}",
          "flags": [
            {"name": "port", "help": "port number", "type": "int", "default": 80, "env": "APP_PORT"}
          ]
        }
      ]
    },
    "argv": ["run"],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "port=9090"
    }
  },
  {
    "name": "config: precedence - CLI wins over config",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "port = 9090",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "port={port}",
          "flags": [
            {"name": "port", "help": "port number", "type": "int", "default": 80, "env": "APP_PORT"}
          ]
        }
      ]
    },
    "argv": ["run", "--port", "8080"],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "port=8080"
    }
  },
  {
    "name": "config: precedence - env wins over config",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "port = 9090",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "port={port}",
          "flags": [
            {"name": "port", "help": "port number", "type": "int", "default": 80, "env": "APP_PORT"}
          ]
        }
      ]
    },
    "argv": ["run"],
    "env": {
      "APP_PORT": "7070"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "port=7070"
    }
  },
  {
    "name": "config: config show source attribution (config vs default)",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "count = 10",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "count", "help": "a count", "type": "int", "default": 0},
            {"name": "name", "help": "a name", "type": "str", "default": "world"}
          ]
        }
      ]
    },
    "argv": ["config", "show", "--plain"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "count = 10  (source: config)",
        "name = world  (source: default)"
      ]
    }
  },
  {
    "name": "config: config path uses .toml extension for toml format",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "commands": [
        {
          "name": "greet",
          "help": "say hello",
          "handler_prints": "hello"
        }
      ]
    },
    "argv": ["config", "path"],
    "env": {
      "XDG_CONFIG_HOME": "/tmp/fake-config"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "/tmp/fake-config/myapp/config.toml"
    }
  },
  {
    "name": "config: config set unknown key error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "count", "help": "a count", "type": "int", "default": 0}
          ]
        }
      ]
    },
    "argv": ["config", "set", "nonexistent", "value"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "config set: unknown key 'nonexistent'"
    }
  },
  {
    "name": "config: config set bad int value error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "count", "help": "a count", "type": "int", "default": 0}
          ]
        }
      ]
    },
    "argv": ["config", "set", "count", "abc"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "config set: key 'count'"

  },
  {
    "name": "config: config set bad bool value error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "debug", "help": "debug mode", "type": "bool", "default": false}
          ]
        }
      ]
    },
    "argv": ["config", "set", "debug", "maybe"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "config set: key 'debug'"
    }
  },
  {
    "name": "config: config show --plain output",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "count = 10",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "count", "help": "a count", "type": "int", "default": 0},
            {"name": "name", "help": "a name", "type": "str", "default": "world"}
          ]
        }
      ]
    },
    "argv": ["config", "show", "--plain"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "count = 10  (source: config)",
        "name = world  (source: default)"
      ]

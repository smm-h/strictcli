  {
    "name": "config: config show no flags error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "count", "help": "a count", "type": "int", "default": 0}
          ]
        }
      ]
    },
    "argv": ["config", "show"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "one of --plain, --json is required"

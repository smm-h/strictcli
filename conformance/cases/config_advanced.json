  },
  {
    "name": "config: config show --json output",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "count = 10",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "count", "help": "a count", "type": "int", "default": 0},
            {"name": "name", "help": "a name", "type": "str", "default": "world"}
          ]
        }
      ]
    },
    "argv": ["config", "show", "--json"],
    "expect": {
      "exit_code": 0,

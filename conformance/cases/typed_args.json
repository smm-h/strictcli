[
  {
    "name": "typed args: int arg valid input",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "count",
              "help": "a count",
              "type": "int"
            }
          ],
          "handler_prints": "count={count}"
        }
      ]
    },
    "argv": ["cmd", "42"],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "count=42"
    }
  },
  {
    "name": "typed args: int arg invalid input",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "count",
              "help": "a count",
              "type": "int"
            }
          ],
          "handler_prints": "count={count}"
        }
      ]
    },
    "argv": ["cmd", "abc"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": ["expected integer", "'abc'"],
      "stderr_equals": "error: argument 'count': expected integer, got 'abc'\ntry 'myapp cmd --help'"
    }
  },

  {
    "name": "typed args: int arg with choices valid",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "level",
              "help": "verbosity level",
              "type": "int",
              "choices_int": [0, 1, 2]
            }
          ],
          "handler_prints": "level={level}"
        }
      ]
    },
    "argv": ["cmd", "1"],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "level=1"
    }
  },
  {
    "name": "typed args: int arg with choices invalid",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "level",
              "help": "verbosity level",
              "type": "int",
              "choices_int": [0, 1, 2]
            }
          ],
          "handler_prints": "level={level}"
        }
      ]
    },
    "argv": ["cmd", "5"],
    "expect": {
      "exit_code": 1,

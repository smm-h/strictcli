  {
    "name": "nesting: 3-level dispatch",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "dns",
          "help": "manage DNS",
          "groups": [
            {
              "name": "zone",
              "help": "manage zones",
              "commands": [
                {
                  "name": "list",
                  "help": "list all zones",
                  "handler_prints": "listing zones"
                }
              ]
            }
          ]
        }
      ]
    },
    "argv": ["dns", "zone", "list"],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "listing zones"
    }
  },
  {
    "name": "nesting: 3-level subgroup help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "dns",
          "help": "manage DNS",
          "groups": [
            {
              "name": "zone",
              "help": "manage zones",
              "commands": [
                {
                  "name": "list",
                  "help": "list all zones",
                  "handler_prints": "ok"
                },
                {
                  "name": "create",
                  "help": "create a zone",
                  "handler_prints": "ok"
                }
              ]
            }
          ]
        }
      ]
    },
    "argv": ["dns", "zone", "--help"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": ["list", "create", "manage zones"],
      "stdout_equals": "myapp dns zone -- manage zones\n\nCommands:\n  list      list all zones\n  create    create a zone\n\nUse 'myapp dns zone <command> --help' for more information."
    }
  },
  {
    "name": "nesting: 3-level parent group help shows subgroups",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "dns",
          "help": "manage DNS",
          "commands": [
            {
              "name": "status",
              "help": "show DNS status",
              "handler_prints": "ok"
            }
          ],
          "groups": [
            {
              "name": "zone",
              "help": "manage zones",
              "commands": [
                {
                  "name": "list",
                  "help": "list all zones",
                  "handler_prints": "ok"
                }
              ]
            }
          ]
        }
      ]
    },
    "argv": ["dns", "--help"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": ["Commands:", "Groups:", "status", "zone", "manage zones"],
      "stdout_equals": "myapp dns -- manage DNS\n\nCommands:\n  status    show DNS status\n\nGroups:\n  zone    manage zones\n\nUse 'myapp dns <command> --help' for more information."
    }
  },

[
  {
    "name": "nesting: group command dispatch",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "show",
              "help": "display config",
              "handler_prints": "showing config"
            }
          ]
        }
      ]
    },
    "argv": [
      "config",
      "show"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "showing config"
    }
  },
  {
    "name": "nesting: group command with flags",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "set",
              "help": "set a config value",
              "flags": [
                {
                  "name": "key",
                  "type": "str",
                  "help": "config key"
                },
                {
                  "name": "value",
                  "type": "str",
                  "help": "config value"
                }
              ],
              "handler_prints": "{key}={value}"
            }
          ]
        }
      ]
    },
    "argv": [
      "config",
      "set",
      "--key",
      "name",
      "--value",
      "strictcli"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "name=strictcli"
    }
  },
  {
    "name": "nesting: unknown group subcommand error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "show",
              "help": "display config",
              "handler_prints": "ok"
            }
          ]
        }
      ]
    },
    "argv": [
      "config",
      "delete"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "unknown command",
      "stderr_equals": "error: unknown command 'delete'\ntry 'myapp --help'"
    }
  },
  {
    "name": "nesting: group help shows subcommands",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "show",
              "help": "display config",
              "handler_prints": "ok"
            },
            {
              "name": "set",
              "help": "set a config value",
              "handler_prints": "ok"
            }
          ]
        }
      ]
    },
    "argv": [
      "config",
      "--help"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "show",
        "set",
        "display config",
        "set a config value"
      ],
      "stdout_equals": "myapp config -- manage configuration\n\nCommands:\n  show    display config\n  set     set a config value\n\nUse 'myapp config <command> --help' for more information."
    }
  },
  {
    "name": "nesting: group help via -h",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "show",
              "help": "display config",
              "handler_prints": "ok"
            }
          ]
        }
      ]
    },
    "argv": [
      "config",
      "-h"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "manage configuration",
      "stdout_equals": "myapp config -- manage configuration\n\nCommands:\n  show    display config\n\nUse 'myapp config <command> --help' for more information."
    }
  },
  {
    "name": "nesting: group with no subcommand shows group help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "show",
              "help": "display config",
              "handler_prints": "ok"
            }
          ]
        }
      ]
    },
    "argv": [
      "config"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "manage configuration",
        "show"
      ],
      "stdout_equals": "myapp config -- manage configuration\n\nCommands:\n  show    display config\n\nUse 'myapp config <command> --help' for more information."
    }
  },
  {
    "name": "nesting: nested command help shows group prefix",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "set",
              "help": "set a config value",
              "flags": [
                {
                  "name": "key",
                  "type": "str",
                  "help": "config key"
                },
                {
                  "name": "value",
                  "type": "str",
                  "help": "config value"
                }
              ],
              "handler_prints": "ok"
            }
          ]
        }
      ]
    },
    "argv": [
      "config",
      "set",
      "--help"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "config set",
      "stdout_equals": "myapp config set -- set a config value\n\nFlags:\n  --key <str>      config key [required]\n  --value <str>    config value [required]"
    }
  },
  {
    "name": "nesting: group use hint",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "show",
              "help": "display config",
              "handler_prints": "ok"
            }
          ]
        }
      ]
    },
    "argv": [
      "config",
      "--help"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "Use 'myapp config <command> --help' for more information.",
      "stdout_equals": "myapp config -- manage configuration\n\nCommands:\n  show    display config\n\nUse 'myapp config <command> --help' for more information."
    }
  }
]

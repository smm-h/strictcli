  },
  {
    "name": "nesting: nested command help shows group prefix",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "set",
              "help": "set a config value",
              "flags": [
                {
                  "name": "key",
                  "type": "str",
                  "help": "config key"
                },
                {
                  "name": "value",
                  "type": "str",
                  "help": "config value"
                }
              ],
              "handler_prints": "ok"
            }
          ]
        }
      ]
    },
    "argv": [
      "config",
      "set",
      "--help"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "config set",
      "stdout_equals": "myapp config set -- set a config value\n\nFlags:\n  --key <str>      config key [required]\n  --value <str>    config value [required]"
    }
  },
  {
    "name": "nesting: group use hint",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",

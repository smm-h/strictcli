[
  {
    "name": "choices: valid str choice accepted",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "choices_str": [
                "text",
                "json"
              ]
            }
          ],
          "handler_prints": "format={format}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--format",
      "json"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "format=json"
    }
  },
  {
    "name": "choices: invalid str choice rejected",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "choices_str": [
                "text",
                "json"
              ]
            }
          ],
          "handler_prints": "format={format}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--format",
      "xml"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "invalid value",
        "'xml'",
        "text",
        "json"
      ],
      "stderr_equals": "error: --format: invalid value 'xml', must be one of: text, json\ntry 'myapp cmd --help'"
    }
  },
  {
    "name": "choices: shown in help output",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "choices_str": [
                "text",
                "json"
              ],
              "default": "text"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "--help"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "choices: text, json",
      "stdout_equals": "myapp cmd -- a command\n\nFlags:\n  --format <str>    output format [choices: text, json] [default: text]"
    }
  },
  {
    "name": "choices: valid int choice accepted",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "port",
              "type": "int",
              "help": "the port",
              "choices_int": [
                80,
                443,
                8080
              ]
            }
          ],
          "handler_prints": "port={port}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--port",
      "443"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "port=443"
    }
  },
  {
    "name": "choices: invalid int choice rejected",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "port",
              "type": "int",
              "help": "the port",
              "choices_int": [
                80,
                443,
                8080
              ]
            }
          ],
          "handler_prints": "port={port}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--port",
      "9090"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "invalid value",
        "9090"
      ],
      "stderr_equals": "error: --port: invalid value '9090', must be one of: 80, 443, 8080\ntry 'myapp cmd --help'"
    }
  },
  {
    "name": "choices: env var with valid choice accepted",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "choices_str": [
                "text",
                "json"
              ],
              "default": "text",
              "env": "MYAPP_FORMAT"
            }
          ],
          "handler_prints": "format={format}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "MYAPP_FORMAT": "json"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "format=json"
    }
  },
  {
    "name": "choices: env var with invalid choice rejected",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "format",
              "type": "str",
              "help": "output format",
              "choices_str": [
                "text",
                "json"
              ],
              "default": "text",
              "env": "MYAPP_FORMAT"
            }
          ],
          "handler_prints": "format={format}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "MYAPP_FORMAT": "xml"
    },
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "invalid value",
        "'xml'"
      ],
      "stderr_equals": "error: --format: invalid value 'xml', must be one of: text, json\ntry 'myapp cmd --help'"
    }
  }
]

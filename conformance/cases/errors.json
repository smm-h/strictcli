[
  {
    "name": "errors: unknown flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "--unknown"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "unknown flag",
      "stderr_equals": "error: unknown flag '--unknown'\ntry 'myapp --help'"
    }
  },
  {
    "name": "errors: unknown short flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "-x"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "unknown flag",
      "stderr_equals": "error: unknown flag '-x'\ntry 'myapp --help'"
    }
  },
  {
    "name": "errors: missing required str flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "--target",
        "required"
      ],
      "stderr_equals": "error: flag '--target' is required\ntry 'myapp --help'"
    }
  },
  {
    "name": "errors: extra positional arg",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "surprise"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "unexpected argument",
      "stderr_equals": "error: unexpected argument 'surprise'\ntry 'myapp --help'"
    }
  },
  {
    "name": "errors: flag requires a value",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "--target"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "requires a value",
      "stderr_equals": "error: flag '--target' requires a value\ntry 'myapp --help'"
    }
  },
  {
    "name": "errors: error message includes try hint",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "unknown"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "unknown command",
        "try 'myapp --help'"
      ],
      "stderr_equals": "error: unknown command 'unknown'\ntry 'myapp --help'"
    }
  },
  {
    "name": "errors: bool negation with value is rejected",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "--no-verbose=true"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "boolean negation",
      "stderr_equals": "error: flag '--no-verbose' is a boolean negation and does not take a value\ntry 'myapp --help'"
    }
  },
  {
    "name": "errors: str flag value looks like unknown flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target"
            }
          ],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--target",
      "--unknown"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "target=--unknown"
    }
  },
  {
    "name": "errors: str flag value looks like known flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target"
            },
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose"
            }
          ],
          "handler_prints": "target={target} verbose={verbose}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--target",
      "--verbose"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "target=--verbose verbose=false"
    }
  },
  {
    "name": "errors: unknown flag in equals form",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "--unknown=value"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "unknown flag",
      "stderr_equals": "error: unknown flag '--unknown'\ntry 'myapp --help'"
    }
  }
]

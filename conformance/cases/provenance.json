[
  {
    "name": "context handler: CLI flag source is 'cli', defaulted flag source is 'default'",
    "app": {
      "name": "provenance-test",
      "version": "1.0.0",
      "help": "Test provenance tracking",
      "commands": [
        {
          "name": "run",
          "help": "Run with provenance",
          "handler_style": "context",
          "handler_prints": "{source:output}:{source:verbose}",
          "flags": [
            {
              "name": "output",
              "help": "Output file",
              "type": "str"
            },
            {
              "name": "verbose",
              "help": "Enable verbose mode",
              "type": "bool",
              "default": false
            }
          ]
        }
      ]
    },
    "argv": ["run", "--output", "file.txt"],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "cli:default"
    }
  }
]

[
  {
    "name": "env: str flag from env var",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target",
              "default": "fallback",
              "env": "MYAPP_TARGET"
            }
          ],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "MYAPP_TARGET": "from-env"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "target=from-env"
    }
  },
  {
    "name": "env: CLI overrides env var",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target",
              "default": "fallback",
              "env": "MYAPP_TARGET"
            }
          ],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--target",
      "from-cli"
    ],
    "env": {
      "MYAPP_TARGET": "from-env"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "target=from-cli"
    }
  },
  {

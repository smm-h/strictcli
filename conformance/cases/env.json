[
  {
    "name": "env: str flag from env var",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "target", "type": "str", "help": "the target", "default": "fallback", "env": "MYAPP_TARGET"}],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": ["cmd"],
    "env": {"MYAPP_TARGET": "from-env"},
    "expect": {
      "exit_code": 0,
      "stdout_contains": "target=from-env"
    }
  },
  {
    "name": "env: CLI overrides env var",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "target", "type": "str", "help": "the target", "default": "fallback", "env": "MYAPP_TARGET"}],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": ["cmd", "--target", "from-cli"],
    "env": {"MYAPP_TARGET": "from-env"},
    "expect": {
      "exit_code": 0,
      "stdout_contains": "target=from-cli"
    }
  },
  {
    "name": "env: bool env var true",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "verbose", "type": "bool", "help": "be verbose", "env": "MYAPP_VERBOSE"}],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": ["cmd"],
    "env": {"MYAPP_VERBOSE": "true"},
    "expect": {
      "exit_code": 0,
      "stdout_contains": "verbose=true"
    }
  },
  {
    "name": "env: bool env var 1",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "verbose", "type": "bool", "help": "be verbose", "env": "MYAPP_VERBOSE"}],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": ["cmd"],
    "env": {"MYAPP_VERBOSE": "1"},
    "expect": {
      "exit_code": 0,
      "stdout_contains": "verbose=true"
    }
  },
  {
    "name": "env: bool env var yes",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "verbose", "type": "bool", "help": "be verbose", "env": "MYAPP_VERBOSE"}],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": ["cmd"],
    "env": {"MYAPP_VERBOSE": "yes"},
    "expect": {
      "exit_code": 0,
      "stdout_contains": "verbose=true"
    }
  },
  {
    "name": "env: bool env var false",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "verbose", "type": "bool", "help": "be verbose", "env": "MYAPP_VERBOSE"}],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": ["cmd"],
    "env": {"MYAPP_VERBOSE": "false"},
    "expect": {
      "exit_code": 0,
      "stdout_contains": "verbose=false"
    }
  },
  {
    "name": "env: bool env var 0",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "verbose", "type": "bool", "help": "be verbose", "env": "MYAPP_VERBOSE"}],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": ["cmd"],
    "env": {"MYAPP_VERBOSE": "0"},
    "expect": {
      "exit_code": 0,
      "stdout_contains": "verbose=false"
    }
  },
  {
    "name": "env: invalid bool env var rejected",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "verbose", "type": "bool", "help": "be verbose", "env": "MYAPP_VERBOSE"}],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": ["cmd"],
    "env": {"MYAPP_VERBOSE": "maybe"},
    "expect": {
      "exit_code": 1,
      "stderr_contains": "invalid boolean value"
    }
  },
  {
    "name": "env: prefixed=false env var",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "target", "type": "str", "help": "the target", "default": "fallback", "env": "SPECIAL", "prefixed": false}],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": ["cmd"],
    "env": {"SPECIAL": "works"},
    "expect": {
      "exit_code": 0,
      "stdout_contains": "target=works"
    }
  },
  {
    "name": "env: env var shown in help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [{"name": "target", "type": "str", "help": "the target", "default": "x", "env": "MYAPP_TARGET"}],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": ["cmd", "--help"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "env: MYAPP_TARGET"
    }
  }
]

  {
    "name": "env: env var shown in help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target",
              "default": "x",
              "env": "MYAPP_TARGET"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "--help"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "env: MYAPP_TARGET",
      "stdout_equals": "myapp cmd -- a command\n\nFlags:\n  --target <str>    the target [env: MYAPP_TARGET] [default: x]"
    }
  }
]

          "flags": [
            {
              "name": "target",
              "type": "str",
              "help": "the target",
              "default": "fallback",
              "env": "SPECIAL",
              "prefixed": false
            }
          ],
          "handler_prints": "target={target}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {

              "help": "be verbose",
              "env": "MYAPP_VERBOSE"
            }
          ],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "MYAPP_VERBOSE": "true"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "verbose=true"
    }
  },

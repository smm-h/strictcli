[
  {
    "name": "cross_feature: required bool in mutex group, only string provided",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "mutex": [
            {
              "flags": [
                {
                  "name": "force-mode",
                  "type": "bool",
                  "help": "force mode"
                },
                {
                  "name": "target",
                  "type": "str",
                  "help": "target name",
                  "default": null
                }
              ]
            }
          ],
          "handler_prints": "force-mode={force-mode} target={target}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--target",
      "prod"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "force-mode=None target=prod"
    }
  },
  {
    "name": "cross_feature: required bool in mutex group, neither provided is error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "mutex": [
            {
              "flags": [
                {
                  "name": "force-mode",
                  "type": "bool",
                  "help": "force mode"
                },
                {
                  "name": "target",
                  "type": "str",
                  "help": "target name",
                  "default": null
                }
              ]
            }
          ],
          "handler_prints": "force-mode={force-mode} target={target}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "one of",
        "is required"
      ]
    }
  },
  {
    "name": "cross_feature: required bool in mutex group, bool provided",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "mutex": [
            {
              "flags": [
                {
                  "name": "force-mode",
                  "type": "bool",
                  "help": "force mode"
                },
                {
                  "name": "target",
                  "type": "str",
                  "help": "target name",
                  "default": null
                }
              ]
            }
          ],
          "handler_prints": "force-mode={force-mode} target={target}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--force-mode"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "force-mode=true target=None"
    }
  },
  {
    "name": "cross_feature: required bool global flag satisfied by env var",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "global_flags": [
        {
          "name": "force-mode",
          "type": "bool",
          "help": "force mode",
          "env": "MYAPP_FORCE_MODE"
        }
      ],
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "force-mode={force-mode}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "MYAPP_FORCE_MODE": "true"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "force-mode=true"
    }
  },
  {
    "name": "cross_feature: required bool global flag missing without env var",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "global_flags": [
        {
          "name": "force-mode",
          "type": "bool",

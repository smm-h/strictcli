          "env": "MYAPP_FORCE_MODE"
        }
      ],
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "force-mode={force-mode}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "must be passed"
    }
  },
  {
    "name": "cross_feature: tag contract requires a required bool flag, invoked without flag",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "tag_contracts": {
        "strict": { "requires_flag": "strict" }
      },
      "commands": [
        {
          "name": "lint",
          "help": "lint code",
          "tags": ["strict"],
          "flags": [
            {
              "name": "strict",
              "type": "bool",
              "help": "strict mode"
            }
          ],
          "handler_prints": "strict={strict}"
        }
      ]
    },
    "argv": [
      "lint"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "must be passed"
    }
  },
  {

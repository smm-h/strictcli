  {
    "name": "cross_feature: global flag value printed in handler output",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "global_flags": [
        {
          "name": "format",
          "type": "str",
          "help": "output format",
          "default": "text"
        }
      ],
      "commands": [
        {
          "name": "show",
          "help": "show data",
          "flags": [
            {
              "name": "item",
              "type": "str",
              "help": "item to show"
            }
          ],
          "handler_prints": "format={format} item={item}"
        }
      ]
    },
    "argv": [
      "--format",
      "json",
      "show",
      "--item",
      "config"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "format=json item=config"
    }
  },
  {
    "name": "cross_feature: global flag default value visible in handler output",
    "app": {
      "name": "myapp",
      "version": "1.0.0",

[
  {
    "name": "env separator: split on comma",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "tag",
              "type": "str",
              "help": "a tag",
              "repeatable": true,
              "unique": false,
              "env": "TAGS",
              "env_separator": ","
            }
          ],
          "handler_prints": "tags={tag}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "TAGS": "a,b,c"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "tags=a,b,c"
    }
  },
  {
    "name": "env separator: escaped separator",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "tag",
              "type": "str",
              "help": "a tag",
              "repeatable": true,
              "unique": false,
              "env": "TAGS",
              "env_separator": ","
            }
          ],
          "handler_prints": "tags={tag}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "TAGS": "a\\,b,c"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "tags=a,b,c"
    }
  },
  {
    "name": "env separator: single value (no separator in value)",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "tag",
              "type": "str",
              "help": "a tag",
              "repeatable": true,
              "unique": false,
              "env": "TAGS",
              "env_separator": ","
            }
          ],
          "handler_prints": "tags={tag}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "TAGS": "a"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "tags=a"
    }
  },
  {
    "name": "env separator: int coercion per element",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "count",
              "type": "int",
              "help": "a count",
              "repeatable": true,
              "unique": false,
              "env": "COUNTS",
              "env_separator": ","
            }
          ],
          "handler_prints": "counts={count}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "COUNTS": "1,2,3"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "counts=1,2,3"
    }
  },
  {
    "name": "env separator: CLI overrides env entirely",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "tag",
              "type": "str",
              "help": "a tag",
              "repeatable": true,
              "unique": false,
              "env": "TAGS",
              "env_separator": ","
            }
          ],
          "handler_prints": "tags={tag}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--tag",
      "from-cli"
    ],
    "env": {
      "TAGS": "x,y,z"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "tags=from-cli"
    }
  },
  {
    "name": "env separator: unique enforcement from env",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "tag",
              "type": "str",
              "help": "a tag",
              "repeatable": true,
              "unique": true,
              "env": "TAGS",
              "env_separator": ","
            }
          ],
          "handler_prints": "tags={tag}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "TAGS": "a,b,a"
    },
    "expect": {
      "exit_code": 1,
      "stderr_contains": "--tag: duplicate value 'a' (from env var 'TAGS')"
    }
  },
  {

[
  {
    "name": "passthrough: receives raw args",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}"
        }
      ]
    },
    "argv": [
      "checkout",
      "-b",
      "feature"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "checkout:-b,feature"
    }
  },
  {
    "name": "passthrough: flags that look like flags are not parsed",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "merge",
          "help": "merge branches",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}"
        }
      ]
    },
    "argv": [
      "merge",
      "--no-ff",
      "main"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "merge:--no-ff,main"
    }
  },
  {
    "name": "passthrough: no args gives empty args",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "status",
          "help": "show status",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}"
        }
      ]
    },
    "argv": [
      "status"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "status:"
    }
  },
  {
    "name": "passthrough: with global flags",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "global_flags": [
        {
          "name": "verbose",
          "type": "bool",
          "help": "enable verbose output",
          "default": false
        }
      ],
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}"
        }
      ]
    },
    "argv": [
      "--verbose",
      "checkout",
      "-b",
      "foo"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "verbose=true",
        "checkout:-b,foo"
      ],
      "stdout_equals": "verbose=true\ncheckout:-b,foo"
    }
  },
  {
    "name": "passthrough: global flag after command name stays in args",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "global_flags": [
        {
          "name": "verbose",
          "type": "bool",
          "help": "enable verbose output",
          "default": false
        }
      ],
      "commands": [
        {
          "name": "raw",
          "help": "run raw command",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}"
        }
      ]
    },
    "argv": [
      "raw",
      "--verbose"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "verbose=false",
        "raw:--verbose"
      ],
      "stdout_equals": "verbose=false\nraw:--verbose"
    }
  },
  {
    "name": "passthrough: command shown in app help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}"
        },
        {
          "name": "status",
          "help": "show status",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "checkout",
        "checkout a branch",
        "status"
      ],
      "stdout_equals": "myapp v1.0.0 -- test app\n\nCommands:\n  checkout    checkout a branch\n  status      show status\n\nUse 'myapp <command> --help' for more information."
    }
  },
  {
    "name": "passthrough: command help shows help text without flags section",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}"
        }
      ]
    },
    "argv": [
      "checkout",
      "--help"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "checkout a branch",
      "stdout_not_contains": "Flags:",
      "stdout_equals": "myapp checkout -- checkout a branch"
    }
  },
  {
    "name": "passthrough: with flags declaration is registration error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}",
          "flags": [
            {
              "name": "force",
              "type": "bool",
              "help": "force",
              "default": false
            }
          ]
        }
      ]
    },
    "argv": [
      "checkout"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "passthrough",
      "stderr_equals": "error: command \"checkout\": passthrough commands cannot have flags"
    }
  },
  {
    "name": "passthrough: with args declaration is registration error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}",
          "args": [
            {
              "name": "branch",
              "help": "branch name"
            }
          ]
        }
      ]
    },
    "argv": [
      "checkout"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "passthrough",
      "stderr_equals": "error: command \"checkout\": passthrough commands cannot have args"
    }
  },
  {
    "name": "passthrough: handler returns nonzero exit code",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}",
          "handler_exit_code": 3
        }
      ]
    },
    "argv": [
      "checkout",
      "-b",
      "feature"
    ],
    "expect": {
      "exit_code": 3,
      "stdout_equals": "checkout:-b,feature"
    }
  },
  {
    "name": "passthrough: custom handler_prints template",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "exec",
          "help": "execute a command",
          "passthrough": true,
          "passthrough_handler_prints": "cmd={name} rest={args}"
        }
      ]
    },
    "argv": [
      "exec",
      "--verbose",
      "deploy"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "cmd=exec rest=--verbose,deploy"
    }
  },
  {
    "name": "passthrough: multiple passthrough commands",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}"
        },
        {
          "name": "merge",
          "help": "merge branches",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}"
        }
      ]
    },
    "argv": [
      "merge",
      "--squash",
      "dev"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "merge:--squash,dev"
    }
  },
  {
    "name": "passthrough: with flag sets only is registration error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}",
          "flag_sets": [
            {
              "name": "output",
              "flags": [
                {
                  "name": "verbose",
                  "type": "bool",
                  "help": "verbose output"
                }
              ]
            }
          ]
        }
      ]
    },
    "argv": [
      "checkout"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "passthrough",
      "stderr_equals": "error: command \"checkout\": passthrough commands cannot have flag sets"
    }
  },
  {
    "name": "passthrough: with mutex only is registration error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "checkout",
          "help": "checkout a branch",
          "passthrough": true,
          "passthrough_handler_prints": "{name}:{args}",
          "mutex": [
            {
              "flags": [
                {
                  "name": "verbose",
                  "type": "bool",
                  "help": "verbose output"
                },
                {
                  "name": "quiet",
                  "type": "bool",
                  "help": "quiet output"
                }
              ]
            }
          ]
        }
      ]
    },
    "argv": [
      "checkout"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "passthrough",
      "stderr_equals": "error: command \"checkout\": passthrough commands cannot have mutex groups"
    }
  },
  {
    "name": "passthrough: in group works",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "git",
          "help": "git operations",
          "commands": [
            {
              "name": "checkout",
              "help": "checkout a branch",
              "passthrough": true,
              "passthrough_handler_prints": "{name}:{args}"
            }
          ]
        }
      ]
    },
    "argv": [
      "git",
      "checkout",
      "-b",
      "feature"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "checkout:-b,feature"
    }
  }
]

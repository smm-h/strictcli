[
  {
    "name": "mutex: neither provided is error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "mutex": [
            {
              "flags": [
                {
                  "name": "verbose",
                  "type": "bool",
                  "help": "verbose output"
                },
                {
                  "name": "quiet",
                  "type": "bool",
                  "help": "quiet output"
                }
              ]
            }
          ],
          "handler_prints": "verbose={verbose} quiet={quiet}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "one of",
        "is required"
      ]
    }
  },
  {
    "name": "mutex: one provided is ok",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "mutex": [
            {
              "flags": [
                {
                  "name": "verbose",
                  "type": "bool",
                  "help": "verbose output"
                },
                {
                  "name": "quiet",
                  "type": "bool",
                  "help": "quiet output"
                }
              ]
            }
          ],
          "handler_prints": "verbose={verbose} quiet={quiet}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--verbose"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "verbose=true",
        "quiet=false"
      ],
      "stdout_equals": "verbose=true quiet=false"
    }
  },

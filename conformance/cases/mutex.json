  {
    "name": "mutex: help shows mutually exclusive section",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "name",
              "type": "str",
              "help": "your name",
              "default": "anon"
            }
          ],
          "mutex": [
            {
              "flags": [
                {
                  "name": "verbose",
                  "type": "bool",
                  "help": "verbose output"
                },
                {
                  "name": "quiet",
                  "type": "bool",
                  "help": "quiet output"
                }
              ]
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd",
      "--help"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "Flags (mutually exclusive):",
        "--verbose",
        "--quiet",
        "Flags:",
        "--name"
      ],
      "stdout_equals": "myapp cmd -- a command\n\nFlags:\n  --name <str>    your name [default: anon]\n\nFlags (mutually exclusive):\n  --verbose, --no-verbose    verbose output [default: false]\n  --quiet, --no-quiet        quiet output [default: false]"
    }
  },

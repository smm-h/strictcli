[
  {
    "name": "composition: mutex + env, one set via env is ok",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "mutex": [
            {
              "flags": [
                {
                  "name": "file",
                  "type": "str",
                  "help": "read from file",
                  "default": null,
                  "env": "MYAPP_FILE"
                },
                {
                  "name": "url",
                  "type": "str",
                  "help": "read from URL",
                  "default": null,
                  "env": "MYAPP_URL"
                }
              ]
            }
          ],
          "handler_prints": "file={file} url={url}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "MYAPP_FILE": "data.txt"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "file=data.txt url=None"
    }
  },
  {
    "name": "composition: mutex + env, both set via env is error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "mutex": [
            {
              "flags": [
                {
                  "name": "file",
                  "type": "str",
                  "help": "read from file",
                  "default": null,
                  "env": "MYAPP_FILE"
                },
                {
                  "name": "url",
                  "type": "str",
                  "help": "read from URL",
                  "default": null,
                  "env": "MYAPP_URL"
                }
              ]
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "MYAPP_FILE": "data.txt",
      "MYAPP_URL": "http://example.com"
    },
    "expect": {
      "exit_code": 1,
      "stderr_contains": [
        "--file",
        "--url",
        "mutually exclusive"
      ],
      "stderr_equals": "error: --file and --url are mutually exclusive\ntry 'myapp cmd --help'"
    }
  },
  {
    "name": "composition: global_flags + choices, valid choice accepted",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",

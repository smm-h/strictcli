        {
          "name": "format",
          "type": "str",
          "help": "output format",
          "choices_str": [
            "text",
            "json"
          ],
          "default": "text"
        }
      ],
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "format={format}"
        }
      ]
    },
    "argv": [
      "--format",
      "json",
      "cmd"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "format=json"
    }
  },

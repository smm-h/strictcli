  {
    "name": "composition: nesting + mutex, one provided is ok",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [],
      "groups": [
        {
          "name": "config",
          "help": "manage configuration",
          "commands": [
            {
              "name": "set",
              "help": "set a config value",
              "mutex": [
                {
                  "flags": [
                    {
                      "name": "local",
                      "type": "bool",
                      "help": "set local config"
                    },
                    {
                      "name": "system",
                      "type": "bool",
                      "help": "set system config"
                    }
                  ]
                }
              ],
              "handler_prints": "local={local} system={system}"
            }
          ]
        }
      ]
    },
    "argv": [
      "config",
      "set",
      "--local"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "local=true system=false"
    }
  },

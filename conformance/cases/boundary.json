          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "name",
              "type": "str",
              "help": "a name",
              "default": "fallback"
            }
          ],
          "handler_prints": "name={name}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--name",
      "hello world"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "name=hello world"
    }
  },

  {
    "name": "boundary: bool env TRUE uppercase",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "env_prefix": "MYAPP",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "verbose",
              "type": "bool",
              "help": "be verbose",
              "env": "MYAPP_VERBOSE"
            }
          ],
          "handler_prints": "verbose={verbose}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "env": {
      "MYAPP_VERBOSE": "TRUE"
    },
    "expect": {
      "exit_code": 0,
      "stdout_equals": "verbose=true"
    }
  },

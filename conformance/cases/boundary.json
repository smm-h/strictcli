[
  {
    "name": "boundary: empty string as flag value",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "flags": [
            {
              "name": "name",
              "type": "str",
              "help": "a name",
              "default": "fallback"
            }
          ],
          "handler_prints": "name={name}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--name",
      ""
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "name="
    }
  },
  {
    "name": "boundary: string with spaces",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [

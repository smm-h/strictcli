  {
    "name": "boundary: empty argv shows help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "greet",
          "help": "say hello",
          "handler_prints": "hello"
        }
      ]
    },
    "argv": [],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "myapp v1.0.0",
        "Commands:",
        "greet"
      ],
      "stdout_equals": "myapp v1.0.0 -- test app\n\nCommands:\n  greet    say hello\n\nUse 'myapp <command> --help' for more information."
    }
  },
  {
    "name": "boundary: only double dash shows help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "greet",
          "help": "say hello",
          "handler_prints": "hello"
        }
      ]
    },
    "argv": [
      "--"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "myapp v1.0.0",
        "Commands:",
        "greet"
      ],
      "stdout_equals": "myapp v1.0.0 -- test app\n\nCommands:\n  greet    say hello\n\nUse 'myapp <command> --help' for more information."
    }

[
  {
    "name": "variadic: collects multiple values",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "files",
              "help": "files to process",
              "variadic": true
            }
          ],
          "handler_prints": "files={files}"
        }
      ]
    },
    "argv": [
      "cmd",
      "a",
      "b",
      "c"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "files=a,b,c"
    }
  },
  {
    "name": "variadic: collects single value",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "files",
              "help": "files to process",
              "variadic": true
            }
          ],
          "handler_prints": "files={files}"
        }
      ]
    },
    "argv": [
      "cmd",
      "a"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "files=a"
    }
  },
  {
    "name": "variadic: required with zero values is error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "files",
              "help": "files to process",
              "variadic": true
            }
          ],
          "handler_prints": "files={files}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "missing required argument",
      "stderr_equals": "error: missing required argument 'files'\ntry 'myapp cmd --help'"
    }
  },
  {
    "name": "variadic: optional with zero values gives empty list",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "files",
              "help": "files to process",
              "variadic": true,
              "required": false
            }
          ],
          "handler_prints": "files={files}"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "files="
    }
  },
  {
    "name": "variadic: after double dash",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "files",
              "help": "files to process",
              "variadic": true
            }
          ],
          "handler_prints": "files={files}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--",
      "-a",
      "-b"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "files=-a,-b"
    }
  },
  {
    "name": "variadic: with preceding required arg",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "target",
              "help": "build target"
            },
            {
              "name": "files",
              "help": "files to process",
              "variadic": true
            }
          ],
          "handler_prints": "target={target} files={files}"
        }
      ]
    },
    "argv": [
      "cmd",
      "target",
      "f1",
      "f2"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_equals": "target=target files=f1,f2"
    }
  },
  {
    "name": "variadic: shown as name... in help",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "files",
              "help": "files to process",
              "variadic": true
            }
          ],
          "handler_prints": "files={files}"
        }
      ]
    },
    "argv": [
      "cmd",
      "--help"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "files...",
      "stdout_equals": "myapp cmd -- a command\n\nArguments:\n  files...    files to process"
    }
  },
  {
    "name": "variadic: multiple variadic args is registration error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "files",
              "help": "files to process",
              "variadic": true
            },
            {
              "name": "targets",
              "help": "targets",
              "variadic": true
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "variadic",
      "stderr_equals": "error: command \"cmd\": at most one variadic arg is allowed"
    }
  },
  {
    "name": "variadic: not last arg is registration error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "args": [
            {
              "name": "files",
              "help": "files to process",
              "variadic": true
            },
            {
              "name": "target",
              "help": "build target"
            }
          ],
          "handler_prints": "ok"
        }
      ]
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "variadic",
      "stderr_equals": "error: command \"cmd\": variadic arg \"files\" must be the last arg"
    }
  }
]

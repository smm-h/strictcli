  {
    "name": "float format: machine channel (config show --json) keeps JSON number grammar",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "rate = 3.14",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "rate", "help": "a rate", "type": "float", "default": 0.0}
          ]
        }
      ]
    },
    "argv": ["config", "show", "--json"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": [
        "\"rate\"",
        "\"value\": 3.14",
        "\"source\": \"config\""
      ],
      "stdout_not_contains": [
        "\"value\": \"3.14\""
      ]
    }
  }

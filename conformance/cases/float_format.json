          "handler_prints": "rate={rate}"
        }
      ]
    },
    "argv": ["cmd", "--rate", "1e-7"],
    "expect": {
      "exit_code": 1,
      "stderr_equals": "error: --rate: invalid value '1e-7', must be one of: 1.5, 2.5\ntry 'myapp cmd --help'"
    }
  },

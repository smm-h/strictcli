[
  {
    "name": "config-hard-error: malformed TOML is a hard error with position",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_format": "toml",
      "config_content": "key = [unclosed",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "name", "help": "a name", "type": "str", "default": ""}
          ]
        }
      ]
    },
    "argv": ["run"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": ["config file", "line", "column"]
    }
  },
  {
    "name": "config-hard-error: malformed JSON is a hard error with position",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_content": "{\"key\": bad}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "name", "help": "a name", "type": "str", "default": ""}
          ]
        }
      ]
    },
    "argv": ["run"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": ["config file", "line", "column"]
    }
  },
  {
    "name": "config-hard-error: --config missing file is hard error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": ["--config", "/nonexistent/path/config.json", "run"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "config file not found"
    }
  },
  {
    "name": "config-hard-error: config show on broken config shows error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_content": "{broken",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok"
        }
      ]
    },
    "argv": ["config", "show", "--plain"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "config file"
    }
  },
  {
    "name": "config-conflict: error mode config+cli is hard error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_conflict_mode": "error",
      "config_content": "{\"name\": \"from-config\"}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "name", "help": "a name", "type": "str", "default": ""}
          ]
        }
      ]
    },
    "argv": ["run", "--name", "from-cli"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "flag 'name' set in both cli and config; remove one"
    }
  },
  {
    "name": "config-conflict: error mode config+env is hard error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_conflict_mode": "error",
      "config_content": "{\"name\": \"from-config\"}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "name", "help": "a name", "type": "str", "default": "", "env": "MYAPP_NAME"}
          ]
        }
      ]
    },
    "argv": ["run"],
    "env": {
      "MYAPP_NAME": "from-env"
    },
    "expect": {
      "exit_code": 1,
      "stderr_contains": "flag 'name' set in both env and config; remove one"
    }
  },
  {
    "name": "config-conflict: cli-wins mode no error (regression)",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_content": "{\"name\": \"from-config\"}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "name", "help": "a name", "type": "str", "default": ""}
          ]
        }
      ]
    },
    "argv": ["run", "--name", "from-cli"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "ok"
    }
  },
  {
    "name": "config-conflict: error mode identical value co-presence passes",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_conflict_mode": "error",
      "config_content": "{\"name\": \"same\"}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "name", "help": "a name", "type": "str", "default": ""}
          ]
        }
      ]
    },
    "argv": ["run", "--name", "same"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "ok"
    }
  },
  {
    "name": "config-conflict: per-flag error beats app cli-wins",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_conflict_mode": "cli-wins",
      "config_content": "{\"name\": \"from-config\"}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "name", "help": "a name", "type": "str", "default": "", "conflict_mode": "error"}
          ]
        }
      ]
    },
    "argv": ["run", "--name", "from-cli"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "flag 'name' set in both cli and config; remove one"
    }
  },
  {
    "name": "config-conflict: per-flag cli-wins beats app error",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_conflict_mode": "error",
      "config_content": "{\"name\": \"from-config\"}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "name", "help": "a name", "type": "str", "default": "", "conflict_mode": "cli-wins"}
          ]
        }
      ]
    },
    "argv": ["run", "--name", "from-cli"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "ok"
    }
  },
  {
    "name": "config-conflict: plain repeatable same order passes in error mode",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_conflict_mode": "error",
      "config_content": "{\"tag\": [\"a\", \"b\"]}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "tag", "help": "tags", "type": "str", "repeatable": true, "unique": false}
          ]
        }
      ]
    },
    "argv": ["run", "--tag", "a", "--tag", "b"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "ok"
    }
  },
  {
    "name": "config-conflict: plain repeatable different order diverges in error mode",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_conflict_mode": "error",
      "config_content": "{\"tag\": [\"a\", \"b\"]}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "tag", "help": "tags", "type": "str", "repeatable": true, "unique": false}
          ]
        }
      ]
    },
    "argv": ["run", "--tag", "b", "--tag", "a"],
    "expect": {
      "exit_code": 1,
      "stderr_contains": "flag 'tag' set in both cli and config; remove one"
    }
  },
  {
    "name": "config-conflict: unique flag different order is equal (multiset) in error mode",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test app",
      "config": true,
      "config_conflict_mode": "error",
      "config_content": "{\"tag\": [\"a\", \"b\"]}",
      "commands": [
        {
          "name": "run",
          "help": "run command",
          "handler_prints": "ok",
          "flags": [
            {"name": "tag", "help": "tags", "type": "str", "repeatable": true, "unique": true}
          ]
        }
      ]
    },
    "argv": ["run", "--tag", "b", "--tag", "a"],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "ok"
    }
  }
]

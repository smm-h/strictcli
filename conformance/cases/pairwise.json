[
  {
    "name": "pairwise: type=str, short, env, repeatable, choices, mutex",
    "app": {
      "name": "myapp",
      "version": "1.0.0",
      "help": "test",
      "commands": [
        {
          "name": "cmd",
          "help": "a command",
          "handler_prints": "flag0={flag0} alt0={alt0}",
          "mutex": [
            {
              "flags": [
                {
                  "name": "flag0",
                  "type": "str",
                  "help": "test flag 0",
                  "short": "s",
                  "env": "MYAPP_FLAG0",
                  "repeatable": true,
                  "choices_str": [
                    "test_val",
                    "other_val",
                    "third_val"
                  ]
                },
                {
                  "name": "alt0",
                  "type": "str",
                  "help": "mutex companion 0",
                  "default": null
                }
              ]
            }
          ]
        }
      ],
      "env_prefix": "MYAPP"
    },
    "argv": [
      "cmd"
    ],
    "expect": {
      "exit_code": 0,
      "stdout_contains": "flag0=test_val"
    },
    "env": {
      "MYAPP_FLAG0": "test_val"
    }
  },
  {

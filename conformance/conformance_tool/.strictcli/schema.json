  "name": "conformance",
  "version": "0.4.1",
  "help": "Conformance validation tool for strictcli",
  "commands": {
    "check": {
      "name": "check",
      "help": "Run project checks",
      "flags": [
        {
          "name": "all",
          "type": "bool",
          "help": "Run all checks",
          "default": false,
          "negatable": true
        },
        {
          "name": "tag",
          "type": "str",
          "help": "Tag DSL expression to filter checks",
          "default": ""
        },
        {
          "name": "name",
          "type": "str",
          "help": "Glob pattern to filter by check name",
          "default": ""
        },
        {
          "name": "list",
          "type": "bool",
          "help": "List all checks and their tags",
          "default": false,
          "negatable": true
        },
        {
          "name": "json",
          "type": "bool",
          "help": "Output results as JSON",
          "default": false,
          "negatable": true
        },
        {
          "name": "ignore-warnings",
          "type": "bool",
          "help": "Warn severity does not cause nonzero exit",
          "default": false,
          "negatable": true
        },
        {
          "name": "verbose",
          "type": "bool",
          "help": "Show details for passing checks too",
          "default": false,
          "negatable": true
        },
        {
          "name": "dry-run",
          "type": "bool",
          "help": "Show which checks would run without running them",
          "default": false,
          "negatable": true
        }
      ]
    }
  },
  "checks": {
    "api-surface": {
      "tags": [
        "pre-release",
        "fast",
        "parity"
      ],
      "severity": "error",
      "fast": true,
      "pure": true,
      "needs_network": false,
      "depends_on": []
    },
    "error-parity": {
      "tags": [
        "pre-release",
        "fast",
        "parity"
      ],
      "severity": "error",
      "fast": true,
      "pure": true,
      "needs_network": false,
      "depends_on": []
    },
    "conformance-python": {
      "tags": [
        "pre-release",
        "conformance",
        "python"
      ],
      "severity": "error",
      "fast": false,
      "pure": false,
      "needs_network": false,
      "depends_on": []
    },
    "conformance-go": {
      "tags": [
        "pre-release",
        "conformance",
        "go"
      ],
      "severity": "error",
      "fast": false,
      "pure": false,
      "needs_network": false,
      "depends_on": []
    },
    "conformance-parity": {
      "tags": [
        "pre-release",
        "conformance",
        "parity"
      ],
      "severity": "error",
      "fast": false,
      "pure": false,
      "needs_network": false,
      "depends_on": [

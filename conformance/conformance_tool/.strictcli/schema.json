      "groups": {},
      "deprecated": {}
    },
    "flag": {
      "short": null,
      "default": null,
      "env": null,
      "choices": null,
      "repeatable": false,
      "negatable": null,
      "hidden": false
    },
    "arg": {
      "required": true,
      "variadic": false
